
# Postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ComfyUI
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188

# Nombre de threads CPU utilisés par PyTorch dans ComfyUI.
# Par défaut = tous les CPU disponibles. Réduire uniquement si la VM
# est partagée avec d'autres services lourds.
COMFYUI_THREADS=

# Workflow à utiliser :
#   - /app/workflows/sdxl_turbo_txt2img.json  (DreamShaper XL Turbo v2, 1024×1024, ~30-60s CPU)
#   - /app/workflows/sd15_txt2img.json        (DreamShaper 8, 512×512, ~3min CPU — legacy)
WORKFLOW_PATH=/app/workflows/sdxl_turbo_txt2img.json

# Gradio
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860

# Inférence : "comfyui" (prod) ou "mock" (dev rapide / CI)
INFERENCE_BACKEND=comfyui

# Nombre d'images par batch (défaut)
BATCH_SIZE=4

# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
